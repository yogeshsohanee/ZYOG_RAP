projection;
strict ( 2 );

define behavior for zsac_c_bill_header //alias <alias_name>
{
  use create;
  use update;
  use delete;

  use action calculate_netamount;
  use association _item {create;}
}

define behavior for zsac_c_bill_item
{
    use update;
    use delete;

    use association _header;
}